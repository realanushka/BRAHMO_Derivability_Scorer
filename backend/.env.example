# BRAHMO Derivability Scoring System — Environment Variables
# ---------------------------------------------------------------
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your Supabase credentials from:
#    supabase.com → Your Project → Settings → API
# ---------------------------------------------------------------

# Supabase Project URL
# Format: https://<project-id>.supabase.co
# Find at: Project Settings → API → "Project URL"
SUPABASE_URL=https://<your-project-id>.supabase.co

# Supabase Anon/Public Key (NOT the service_role key)
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Find at: Project Settings → API → "Project API keys" → anon / public
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<your-anon-key-here>

# Default organization ID (matches 'id' in organizations table)
DEFAULT_ORG_ID=supra
